# Root-level env for docker-compose. Copy to .env before running
# `docker compose up` if you want to override any default (compose already
# has safe defaults baked in via ${VAR:-default} so `docker compose up`
# works with zero setup too).

JWT_SECRET=dev-only-change-me-shared-secret-for-campaigncell

POSTGRES_IDENTITY_USER=identity
POSTGRES_IDENTITY_PASSWORD=identity
POSTGRES_IDENTITY_DB=identity_db

POSTGRES_CAMPAIGN_USER=campaign
POSTGRES_CAMPAIGN_PASSWORD=campaign
POSTGRES_CAMPAIGN_DB=campaign_db

POSTGRES_AI_USER=ai
POSTGRES_AI_PASSWORD=ai
POSTGRES_AI_DB=ai_db

POSTGRES_GAMIFICATION_USER=gamification
POSTGRES_GAMIFICATION_PASSWORD=gamification
POSTGRES_GAMIFICATION_DB=gamification_db

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Bkz. services/campaign-service/README.md "Vaka Açma Eşiği"
CASE_CONVERSION_THRESHOLD=0.40
